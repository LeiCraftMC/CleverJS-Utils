{
    "compilerOptions": {
        "lib": ["ESNext"],
        "target": "ESNext",
        "moduleResolution": "node",
        "sourceMap": true,
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "paths": {
            "@cleverjs/utils": ["../src/index.ts"]
        }
    },
    "include": [
        "../src/**/*",
        "../samples/**/*",
        "../tests/**/*"
    ]
}
